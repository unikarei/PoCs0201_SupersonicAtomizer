# Example .env for local development - DO NOT commit secrets to VCS
# Copy this to .env and edit the OPENAI_API_KEY value locally.
# Example:
# OPENAI_API_KEY=sk-xxxx-your-key-xxxx
# OPTIONAL: you can also set OPENAI_MODEL or OPENAI_BASE_URL here.

OPENAI_API_KEY=xxx-your-key-xxxx
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
